{
  "permissions": {
    "allow": [
      "Bash(cd:*)",
      "Bash(ls:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/guard.js"
          }
        ]
      }
    ]
  }
}
